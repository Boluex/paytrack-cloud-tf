# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all sensitive variables files
*.tfvars.auth
*.tfvars.local
*.auth.tfvars
*.local.tfvars
*local*.tfvars

# Ignore transient CLI files
.terraform.tfstate.lock.info

# Ignore Lambda zip packaging build directory
**/.build/

